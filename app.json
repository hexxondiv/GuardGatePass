{
  "expo": {
    "name": "Guard Gate Pass",
    "slug": "Guard-Gate-Pass",
    "scheme": "org.gpera.guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/guard_icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/guard_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.gpera.guard"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/guard_adaptive_foreground.png",
        "backgroundColor": "#0d1117"
      },
      "package": "org.gpera.guard",
      "permissions": [
        "android.permission.WAKE_LOCK"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./src/assets/guard_icon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "recordAudioAndroid": false
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Guard Gate Pass to use the camera to scan visitor gate pass QR codes at the estate entrance."
        }
      ]
    ],
    "extra": {
      "appConfig": {
        "devMode": false,
        "apiBaseUrl": "https://api.gpera.org",
        "paystackCallbackBaseUrl": "https://api.gpera.org"
      },
      "eas": {
        "projectId": "f1e8fc79-76ae-4b78-b14c-bf0f82e4fda6"
      }
    },
    "owner": "hexxondiv"
  }
}
