# API host only (no /api/v1 suffix). The app adds /api/v1 for local, emulator, ngrok, and LAN IPs only.
# Production gatepass.hexxondiv.com uses legacy root paths (/login/, …); /api/v1 is not deployed there.
DEV_MODE=false

PROD_API_BASE_URL=https://gatepass.hexxondiv.com
PROD_PAYSTACK_CALLBACK_BASE_URL=https://gatepass.hexxondiv.com

DEV_API_BASE_URL=http://10.0.2.2:8001
# Must match DEV_API_BASE_URL (ngrok or LAN). Required for reliable API host in the JS bundle.
# Use the same value as ResidentGatePass when pointing both apps at a shared ngrok tunnel.
EXPO_PUBLIC_DEV_API_BASE_URL=http://10.0.2.2:8001
DEV_PAYSTACK_CALLBACK_BASE_URL=https://your-tunnel-url.ngrok-free.app
